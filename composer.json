{
  "name": "cmbaughman/salesforce-laravel-oauth2-rest",
  "description": "A Salesforce REST api wrapper utilizing oAuth2",
  "keywords": ["salesforce", "rest", "oauth2"],
  "license": "MIT",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.2.0",
    "ext-json": "*",
    "ext-SimpleXML": "*",
    "ext-libxml": "*",
    "guzzlehttp/guzzle":"^7.8",
    "lcobucci/jwt": "^5.3.0",
    "vlucas/phpdotenv": "^5.6",
    "phpoption/phpoption": "^1.9.3",
    "illuminate/http": "^12.0",
    "illuminate/routing": "^12.0",
    "illuminate/support": "^12.0",
    "illuminate/database": "^12.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6.0",
    "phpunit/phpunit": "^11.5.3"
  },
  "autoload": {
    "classmap": [
      "src/Controllers"
    ],
    "psr-4": {
      "Frankkessler\\Salesforce\\": "src",
      "Frankkessler\\Guzzle\\Oauth2\\": "src/Guzzle/Oauth2"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "files": [
      "tests/GuzzleServer.php",
      "tests/BulkBatchProcessor.php"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Frankkessler\\Salesforce\\Providers\\SalesforceLaravelServiceProvider"
      ],
      "aliases": {
        "Salesforce": "Frankkessler\\Salesforce\\Facades\\Salesforce"
      }
    }
  }
}
